---
/**
 * OptimizedImage component is a modified version of Astro's built-in Image component.
 * It allows to optimize images inside public, src/assets and content folders.
 * To optimize remote images, follow: https://docs.astro.build/en/guides/images/#authorizing-remote-images
 */
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props extends astroHTML.JSX.ImgHTMLAttributes {
  src: string;
  inlineSvg?: boolean;
  alt?: string;
  width?: number | string;
  height?: number | string;
  widths?: number[];
  sizes?: string;
  quality?: number | string;
  loading?: "eager" | "lazy" | null | undefined;
  decoding?: "async" | "auto" | "sync" | null | undefined;
  formats?: "png" | "webp";
  class?: string;
  style?: astroHTML.JSX.CSSProperties | string;
}

// Destructuring Astro.props to get the component's props
let {
  src,
  alt,
  inlineSvg,
  width,
  height,
  widths,
  sizes,
  loading,
  decoding,
  formats,
  style,
  ...rest
} = Astro.props;

const resolvedLoading = loading ?? "lazy";
const resolvedDecoding = decoding ?? "async";

const isRemoteImage = src?.startsWith("http://") || src?.startsWith("https://");
let image: ImageMetadata | null = null;
let SVG: string = "";

if (!isRemoteImage) {
  // Regular Images
  const images = import.meta.glob([
    "/src/assets/images/**/*.{jpeg,jpg,png,avif,tiff,gif,webp,svg,gif}",
    "/public/images/**/*.{jpeg,jpg,png,avif,tiff,gif,webp,svg,gif}",
    "/src/content/**/*.{jpeg,jpg,png,avif,tiff,gif,webp,svg,gif}",
  ]) as Record<string, () => Promise<{ default: ImageMetadata }>>;

  // Get Raw Image For Inline SVG
  const imagesRaw = import.meta.glob(
    [
      "/src/assets/images/**/*.svg",
      "/src/content/**/*.svg",
      "/public/images/**/*.svg",
    ],
    {
      query: "raw",
      import: "default",
    },
  ) as Record<string, () => Promise<string>>;

  if (inlineSvg && src.includes(".svg")) {
    const key = Object.keys(images).find((k) => k.includes(src));
    SVG = key ? await imagesRaw[key]() : "";

    if (SVG.length > 1) {
      let svgParts = SVG.split("<svg"); // Split at the opening <svg> tag

      if (svgParts.length > 1) {
        // Convert rest object to a string of attributes
        const attributes = Object.entries(rest)
          .map(([key, value]) => `${key}="${value}"`)
          .join(" ");

        // Add the attributes to the <svg> tag
        svgParts[1] = ` data-icon="true" ${attributes} ${svgParts[1]}`;
      }

      // Join the array back into a string
      SVG = svgParts.join("<svg");
    }
  }

  const key = Object.keys(images).find((k) => k.includes(src));
  const mod = key ? await images[key]() : null;
  image = mod?.default ?? null;
}
---

{
  inlineSvg && SVG && src.includes(".svg") ? (
    <Fragment set:html={SVG} />
  ) : image ? (
    // @ts-expect-error
    <Image
      style={style}
      alt={alt || ""}
      width={width}
      height={height}
      widths={widths}
      sizes={sizes}
      formats={formats}
      loading={resolvedLoading}
      decoding={resolvedDecoding}
      src={image}
      {...{ class: Astro.props.class }}
      {...rest}
    />
  ) : null
}
